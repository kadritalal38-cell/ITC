def calculate_hp_log_likelihood(observed, predicted):
    resid = observed - predicted
    rss = float(mp.fsum([x**2 for x in resid]))
    variance = rss / len(observed)
    part1 = mp.mpf(-len(observed) / 2) * mp.log(2 * mp.pi * variance)
    part2 = mp.mpf(-rss) / (2 * mp.mpf(variance))
    return float(part1 + part2)

